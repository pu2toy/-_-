<Window x:Class="Task01.View.ClientDialogWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Task01.View"
        mc:Ignorable="d"
        Title="ClientDialogWindow" Height="450" Width="800">
    <Window.Resources>
        <Style x:Key="SaveButtonStyle" TargetType="Button">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="Green" CornerRadius="10" Padding="10">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>
    <Grid>
        <StackPanel>
            <Label Content="ФИО" Margin="20,0 ,0, 0"/>
            <TextBox Margin="20, 0, 20, 0"
                     Text="{Binding Client.FullName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
            <Label Content="Контакт" Margin="20, 0, 0, 0"/>
            <TextBox Margin="20, 0, 20, 0"
                     Text="{Binding Client.Contact, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
            <Label Content="Тип" Margin="20, 0, 0, 0"/>
            <ComboBox Margin="20, 0, 20, 0"
                     ItemsSource="{Binding ClientTypes}"
                     SelectedItem="{Binding Client.ClientType, Mode=OneWay}"/>
        </StackPanel>
        <StackPanel VerticalAlignment="Bottom" Width="200">
            <Button Margin="10" Content="Сохранить" Style="{StaticResource SaveButtonStyle}" Command="{Binding SaveCommand}"/>
            <Button Margin ="10" Content="Отмена" Command="{Binding CancelCommand}"/>
        </StackPanel>
    </Grid>
</Window>
