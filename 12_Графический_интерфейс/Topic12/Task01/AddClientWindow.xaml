<Window x:Class="Task01.AddClientWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Task01"
        mc:Ignorable="d"
        Title="AddClientWindow" Height="450" Width="800">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel>
            <Label Content="ФИО"/>
            <TextBox x:Name="NameBox" Margin="10, 0"/>
            <Label Content="Контакт"/>
            <TextBox x:Name="ContactBox" Margin="10,0"/>
            <Label Content="История"/>
            <TextBox x:Name="HistoryBox" Margin="10, 0"/>
        </StackPanel>

        <Button Grid.Row="1"
                Content="Сохранить"
                Height="30"
                Width="300"
                Click="Save_Click"/>
    </Grid>
</Window>
