@model List<TodoListApp.Models.TodoItem>

<h2>Список задач</h2>

@if (TempData["Message"] != null)
{
    <div style="color: green;">
        @TempData["Message"]
    </div>
}

<form method="post" asp-action="Add">
    <input type="text" name="Description" placeholder="Описание задачи" required />

    <input type="date" name="DueDate" required />

    <button type="submit">Добавить</button>
</form>

<br />

<a href="/Todo">Все</a> |
<a href="/Todo?status=active">Активные</a> |
<a href="/Todo?status=completed">Завершённые</a>

<ul style="list-style: none; padding: 0;">
    @foreach (var item in Model)
    {
        <li style="margin-bottom: 10px; border-bottom: 1px solid #ccc; padding-bottom: 5px">
            <input type="checkbox"
                @(item.IsCompleted ? "checked" : "")
                onchange="location.href='/Todo/Complete/@item.Id'"/>

            <b>@item.Title</b>
            <span style="color: gray;">
            (до: @item.Deadline.ToShortDateString())
            </span>

            @if (!item.IsCompleted)
            {
                <a href="/Todo/Complete/@item.Id" style="margin-left: 10px;">Завершить</a>
            }
            else
            {
                <span style="color: green; margin-left: 10px;">(Готово)</span>
            }

            <a href="/Todo/Delete/@item.Id"
                style="margin-left: 10px; color: red;"
                onclick="return confirm('Удалить задачу?');">X</a>
        </li>
    }
</ul>