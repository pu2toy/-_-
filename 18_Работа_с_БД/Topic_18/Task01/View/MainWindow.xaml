<Window x:Class="Task01.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Task01"
        xmlns:vm="clr-namespace:Task01.ViewModels"
        xmlns:models="clr-namespace:Task01.Models"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <Window.Resources>
        <models:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
    </Window.Resources>
    <Window.DataContext>
        <vm:MainVM/>
    </Window.DataContext>
    <Window.InputBindings>
        <KeyBinding Key="N" Modifiers="Control" Command="{Binding AddClientCommand}"/>
        <KeyBinding Key="E" Modifiers="Control" Command="{Binding EditClientCommand}"/>
        <KeyBinding Key="D" Modifiers="Control" Command="{Binding DeleteClientCommand}"/>
    </Window.InputBindings>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Menu Grid.Row="0">
            <MenuItem Header="Файл"/>
            <MenuItem Header="Клиенты">
                <MenuItem Header="Добавить" Command="{Binding AddClientCommand}" InputGestureText="Ctrl+N"/>
                <MenuItem Header="Редактировать" Command="{Binding EditClientCommand}" InputGestureText="Ctrl+E"/>
                <MenuItem Header="Удалить" Command="{Binding DeleteClientCommand}" InputGestureText="Ctrl+D"/>
            </MenuItem>
            <MenuItem Header="Настройки"/>
        </Menu>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="160"/>
            </Grid.ColumnDefinitions>

            <ListView Margin="10"
                      ItemsSource="{Binding Clients}"
                      SelectedItem="{Binding SelectedClient}">

                <ListView.ItemTemplate>
                    <DataTemplate>
                        <Border BorderBrush="Gray"
                                BorderThickness="1"
                                Margin="5"
                                Padding="10"
                                Height="80"
                                Background="White"
                                MouseEnter="Border_MouseEnter"
                                MouseLeave="Border_MouseLeave"
                                MouseLeftButtonDown="Border_Click">
                            <Border.RenderTransform>
                                <TranslateTransform X="-50"/>
                            </Border.RenderTransform>

                            <Border.Triggers>
                                <EventTrigger RoutedEvent="Loaded">
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation 
                                                Storyboard.TargetProperty="(RenderTransform).(TranslateTransform.X)"
                                                From="-50" To="0"
                                                Duration="0:0:0.3"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </EventTrigger>
                            </Border.Triggers>
                            <StackPanel>
                                <TextBlock Text="{Binding FullName}" FontWeight="Bold" FontSize="14"/>
                                <TextBlock Text="{Binding Contact}"/>
                                <TextBlock Text="{Binding ClientType}">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Foreground" Value="Black"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding ClientType}" Value="VIP">
                                                    <Setter Property="Foreground" Value="Red"/>
                                                    <Setter Property="FontWeight" Value="Bold"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ListView.ItemTemplate>

            </ListView>

            <StackPanel Grid.Column="1" Margin="10">
                <Button Margin="0,10" Content="Добавить" Command="{Binding AddClientCommand}"/>
                <Button Margin="0,5" Content="Редактировать" Command="{Binding EditClientCommand}"/>
                <Button Margin="0,5" Content="Удалить" Command="{Binding DeleteClientCommand}"/>
            </StackPanel>
            <TextBlock Text="Загрузка..."
                HorizontalAlignment="Center"
                VerticalAlignment="Top"
                Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibilityConverter}}"/>
        </Grid>
    </Grid>
</Window>
