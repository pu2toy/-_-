<Window x:Class="Task01.View.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Авторизация"
        Height="350" Width="400"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="#F5F5F5">

    <Grid>
        <Border Background="White"
                CornerRadius="15"
                Padding="30"
                Width="300"
                VerticalAlignment="Center"
                HorizontalAlignment="Center">

            <StackPanel>

                <TextBlock Text="CRM Login"
                           FontSize="22"
                           FontWeight="Bold"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,20"/>

                <TextBlock Text="Логин"/>
                <TextBox Height="30"
                         Margin="0,5,0,10"
                         Text="{Binding Login}"/>

                <TextBlock Text="Пароль"/>
                <PasswordBox x:Name="passBox"
                             Height="30"
                             Margin="0,5,0,20"/>

                <Button Content="Войти"
                        Height="35"
                        Background="#4CAF50"
                        Foreground="White"
                        FontWeight="Bold"
                        BorderThickness="0"
                        Cursor="Hand"
                        Click="Login_Click"/>

            </StackPanel>

        </Border>
    </Grid>
</Window>