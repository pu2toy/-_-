<Window x:Class="Task01.Windows.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Task01.Windows"
        xmlns:vm="clr-namespace:Task01.ViewModels"
        
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <Window.DataContext>
        <vm:MainWindowVM/>
    </Window.DataContext>
    <Window.InputBindings>
        <KeyBinding Key="N" Modifiers="Ctrl" Command="{Binding AddClientCommand}"/>
        <KeyBinding Key="E" Modifiers="Ctrl" Command="{Binding EditClientCommand}"/>
        <KeyBinding Key="D" Modifiers="Ctrl" Command="{Binding DeleteClientCommand}"/>
    </Window.InputBindings>
    <Grid>
        <Menu>
            <MenuItem Header="Файл"/>
            <MenuItem Header="Добавить" Command="{Binding AddClientCommand}"/>
            <MenuItem Header="Настройки"/>
        </Menu>

        <ListView Width="600" HorizontalAlignment="Left" Margin="20, 30, 0, 20"
                  ItemsSource="{Binding Clients}"
                  SelectedItem="{Binding SelectedClient}">
            <ListView.View>
                <GridView>
                    <GridViewColumn Width ="300" Header="ФИО" DisplayMemberBinding="{Binding FullName}"/>
                    <GridViewColumn Width="300" Header="Контакт" DisplayMemberBinding="{Binding Contact}"/>
                </GridView>
            </ListView.View>
        </ListView>

        <StackPanel Width="100" Margin="40" HorizontalAlignment="Right">
            <Button Margin="0, 10" Content="Добавить" Command="{Binding AddClientCommand}"/>
            <Button Margin="0, 5" Content="Редактировать" Command="{Binding EditClientCommand}"/>
            <Button Margin="0, 5" Content="Удалить" Command="{Binding DeleteClientCommand}"/>
        </StackPanel>
    </Grid>
</Window>
